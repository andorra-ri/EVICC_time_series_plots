modifyList(args, extra)
}
build_all_plot_inputs <- function(data, schema) {
global_parameters <- schema$global
input_parameters_list <- list()
for (var_name in names(schema$plots)){
input_parameters_list[[var_name]] <- build_plot_args(data, global_parameters, schema$plots[[var_name]])
}
return(input_parameters_list)
}
